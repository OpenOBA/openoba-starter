# ============================================================
# OpenOBA Starter 环境变量配置模板
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env（项目根目录）
#   2. 根据部署环境修改对应值
#   3. 生产环境务必替换所有弱密钥为强随机字符串
#   4. .env 文件已在 .gitignore 中排除，请勿提交到版本库
# ============================================================

# ---------- 应用环境 ----------
# APP_ENV 是 OpenOBA 应用层环境变量，控制功能开关
# 可选值: development | staging | production
# NODE_ENV 由 Node.js 工具链自动设置（不在此配置）
APP_ENV=development

# 应用端口（后端 API 服务端口）
APP_PORT=3400

# ---------- 部署模式 ----------
# 可选值: operator（运营） | developer（开发） | maintainer（维护）
DEPLOYMENT_MODE=operator
# OPENOBA_MODE 为 v1.3.0 新增统一别名，优先于 DEPLOYMENT_MODE
OPENOBA_MODE=operator

# ---------- 数据库（MySQL） ----------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=openoba_starter

# ---------- JWT 认证 ----------
# ⚠️ 生产环境必须更换为至少 32 字符的强随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_string
# 客户端（C 端）JWT 密钥，与后台管理密钥分离
CUSTOMER_JWT_SECRET=change_me_to_another_random_32_char_string

# ---------- CORS ----------
# 前端访问地址，多个用逗号分隔
CORS_ORIGIN=http://localhost:5173

# ---------- Redis（可选，用于限流和生产环境） ----------
# 不配置时使用内存限流（适合开发单机部署）
# REDIS_URL=redis://localhost:6379

# ---------- 阿里云短信（可选） ----------
# ALIYUN_SMS_ACCESS_KEY_ID=your_access_key
# ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_secret
# ALIYUN_SMS_SIGN_NAME=your_sign_name
# ALIYUN_SMS_TEMPLATE_CODE_LOGIN=your_template_code

# ---------- CDN（可选） ----------
# CDN_BASE_URL=https://cdn.example.com
