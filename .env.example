# 浣跨敤璇存槑锛?#   1. 澶嶅埗姝ゆ枃浠朵负 .env锛堥」鐩牴鐩綍锛?#   2. 鏍规嵁閮ㄧ讲鐜淇敼瀵瑰簲鍊?#   3. 鐢熶骇鐜鍔″繀鏇挎崲鎵€鏈夊急瀵嗛挜涓哄己闅忔満瀛楃涓?#   4. .env 鏂囦欢宸插湪 .gitignore 涓帓闄わ紝璇峰嬁鎻愪氦鍒扮増鏈簱
# ============================================================

# ---------- 搴旂敤鐜 ----------
# APP_ENV 鏄?OpenOBA 搴旂敤灞傜幆澧冨彉閲忥紝鎺у埗鍔熻兘寮€鍏?# 鍙€夊€? development | staging | production
# NODE_ENV 鐢?Node.js 宸ュ叿閾捐嚜鍔ㄨ缃紙涓嶅湪姝ら厤缃級
APP_ENV=development

# 搴旂敤绔彛
APP_PORT=3000

# ---------- 鏁版嵁搴擄紙MySQL锛?----------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_DATABASE=openoba_starter

# ---------- JWT 璁よ瘉 ----------
# 鈿狅笍 鐢熶骇鐜蹇呴』鏇存崲涓鸿嚦灏?32 瀛楃鐨勫己闅忔満瀛楃涓?# 鐢熸垚鏂瑰紡: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_32_char_string
CUSTOMER_JWT_SECRET=change_me_to_another_random_32_char_string

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173

# ---------- Redis锛堝彲閫夛紝鐢ㄤ簬闄愭祦鍜岀敓浜х幆澧冿級 ----------
# 涓嶉厤缃椂浣跨敤鍐呭瓨闄愭祦锛堥€傚悎寮€鍙?鍗曟満閮ㄧ讲锛?# REDIS_URL=redis://localhost:6379

# ---------- 闃块噷浜戠煭淇★紙鍙€夛級 ----------
# ALIYUN_SMS_ACCESS_KEY_ID=your_access_key
# ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_secret
# ALIYUN_SMS_SIGN_NAME=your_sign_name
# ALIYUN_SMS_TEMPLATE_CODE_LOGIN=your_template_code

# ---------- CDN锛堝彲閫夛級 ----------
# CDN_BASE_URL=https://cdn.example.com

# ---------- 閮ㄧ讲妯″紡 ----------
# 鍙€夊€? operator锛堣繍钀ワ級 | developer锛堝紑鍙戯級 | maintainer锛堢淮鎶わ級
DEPLOYMENT_MODE=operator
# OPENOBA_MODE 涓?v1.3.0 鏂板缁熶竴鍒悕锛屼紭鍏堜簬 DEPLOYMENT_MODE
OPENOBA_MODE=operator
