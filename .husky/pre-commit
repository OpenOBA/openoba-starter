echo "🔍 [pre-commit] Running backend tsc --noEmit..."
cd packages/backend
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Backend TypeScript check failed — commit aborted"
  exit 1
fi
echo "✅ [pre-commit] Backend TypeScript passed"

echo "🔍 [pre-commit] Running frontend vue-tsc -b..."
cd ../../frontend
npx vue-tsc -b
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Frontend TypeScript check failed — commit aborted"
  echo "   Run: cd frontend && npx vue-tsc -b  (see errors)"
  exit 1
fi
echo "✅ [pre-commit] Frontend TypeScript passed"

echo "🔍 [pre-commit] Running frontend vitest..."
npx vitest run
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] Frontend tests failed — commit aborted"
  exit 1
fi
echo "✅ [pre-commit] All checks passed"
