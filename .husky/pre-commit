#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 [pre-commit] Running ESLint..."

cd packages/backend
npx eslint "src/**/*.ts" --quiet
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] ESLint failed — commit aborted"
  exit 1
fi

echo "✅ [pre-commit] ESLint passed"

echo "🔍 [pre-commit] Running tsc --noEmit..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ [pre-commit] TypeScript check failed — commit aborted"
  exit 1
fi

echo "✅ [pre-commit] All checks passed"
