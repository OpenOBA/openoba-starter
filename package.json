{
  "name": "openoba-starter",
  "version": "1.3.0",
  "private": true,
  "description": "OpenOBA Starter — AI Executive Officer with Eyewear Reference Implementation",
  "workspaces": [
    "packages/backend",
    "packages/types",
    "frontend"
  ],
  "dependencies": {
    "@nestjs/typeorm": "^10.0.0",
    "typeorm": "^0.3.17"
  },
  "scripts": {
    "build:backend": "npm run build -w packages/backend",
    "start:backend": "node packages/backend/dist/main.js",
    "start:frontend": "npm run dev -w frontend",
    "update-core": "scripts/update-core.bat",
    "lint": "eslint \"packages/backend/src/**/*.ts\"",
    "lint:fix": "eslint \"packages/backend/src/**/*.ts\" --fix",
    "format": "prettier --write \"packages/backend/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/backend/src/**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
