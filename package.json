{
  "name": "openoba-starter",
  "version": "1.4.0-alpha9",
  "private": true,
  "description": "OpenOBA Starter — AI Executive Officer with Eyewear Reference Implementation",
  "workspaces": [
    "packages/backend",
    "packages/core",
    "packages/types",
    "frontend"
  ],
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.26",
"typeorm": "^0.3.17",
    "uuid": "^11.0.0"
  },
  "scripts": {
    "build:backend": "npm run build -w packages/core && npm run build -w packages/backend",
    "lint:core": "npm run lint -w packages/core",
    "lint:backend": "npm run lint -w packages/backend",
    "lint:all": "npm run lint -w packages/core && npm run lint -w packages/backend",
    "start:backend": "node packages/backend/dist/main.js",
    "start:frontend": "npm run dev -w frontend",
    "update-core": "scripts/update-core.bat",
    "lint": "eslint \"packages/backend/src/**/*.ts\"",
    "lint:fix": "eslint \"packages/backend/src/**/*.ts\" --fix",
    "format": "prettier --write \"packages/backend/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/backend/src/**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "husky": "^9.1.7"
  }
}
