# ============================================
# OpenOBA Starter — 环境变量配置模板
# 复制此文件为 .env 后修改各参数
# ⚠️  生产环境务必修改所有带 change_me 的密钥
# ============================================

# 运行环境（development / production）
APP_ENV=development
# 服务端口（默认 3400）
APP_PORT=3400

# CORS（开发环境默认 localhost，生产环境改为实际域名）
CORS_ORIGIN=http://localhost:5173

# Redis（开发环境默认本地，生产环境改为实际地址）
# 若不需要 Redis（回退到内存限流），保持注释或留空
# REDIS_URL=redis://localhost:6379

# MySQL 数据库（建库命令: CREATE DATABASE openoba_starter CHARSET utf8mb4）
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=***
DB_DATABASE=openoba_starter

# JWT（⚠️ 生产环境必须改为随机强密钥，至少 32 字符）
JWT_SECRET=change_me_production_must_replace
# Customer Auth JWT（⚠️ 生产环境必须改为随机强密钥）
CUSTOMER_JWT_SECRET=change_me_production_must_replace

# LLM Provider — 至少配置一个
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# Qwen / 阿里云百炼: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-qwen-key-here

# Skill 密钥加密主钥（⚠️ 至少 32 字符）
SKILL_VAULT_KEY=change_me_production_must_replace_32ch
