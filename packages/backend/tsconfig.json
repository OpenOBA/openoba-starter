{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"],
  "compilerOptions": {
    "module": "commonjs",
    "types": ["node", "jest"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,  // H10备注：启用需清理所有DTO class属性初始化
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["src/*"],
      "@openoba/core/index": ["../../node_modules/@openoba/core/dist/index"],
      "@openoba/core/*": ["../../node_modules/@openoba/core/dist/*"],
      "@openoba/types": ["../../node_modules/@openoba/types/dist"],
      "@openoba/types/*": ["../../node_modules/@openoba/types/dist/*"]
    }
  }
}
